# Database
DATABASE_PROVIDER="sqlite"
DATABASE_URL="file:./koda.db"
# For PostgreSQL: DATABASE_PROVIDER="postgresql" DATABASE_URL="postgresql://user:pass@localhost:5432/koda"
# For MySQL:      DATABASE_PROVIDER="mysql"      DATABASE_URL="mysql://user:pass@localhost:3306/koda"

# JWT
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="change-me-refresh-in-production"
JWT_REFRESH_EXPIRES_IN="30d"

# API
NODE_ENV="development"
API_PORT=3100
GLOBAL_PREFIX="api"
API_KEY_SECRET="change-me-api-key-secret"

# Web
NUXT_PUBLIC_API_BASE_URL="http://localhost:3100/api"
