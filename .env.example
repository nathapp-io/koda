# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3100
API_PREFIX=api

# ── Database ───────────────────────────────────────────────────────────────────
# SQLite (default, zero-config)
DATABASE_PROVIDER=sqlite
DATABASE_URL=file:./koda.db
# PostgreSQL (production)
# DATABASE_PROVIDER=postgresql
# DATABASE_URL=postgresql://user:password@localhost:5432/koda

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-min-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-me-refresh-min-32-chars
JWT_REFRESH_EXPIRES_IN=30d

# ── Agent API Keys ─────────────────────────────────────────────────────────────
API_KEY_SECRET=change-me-api-key-secret-min-32-chars

# ── Web App (Nuxt) ─────────────────────────────────────────────────────────────
NUXT_PUBLIC_API_BASE_URL=http://localhost:3100/api
WEB_PORT=3101
