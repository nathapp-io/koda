{
  "version": 1,
  "quality": {
    "requireTypecheck": true,
    "requireLint": true,
    "requireTests": true,
    "commands": {
      "test": "npx turbo test",
      "testScoped": "npx turbo test --filter=[HEAD^1]",
      "typecheck": "bunx turbo type-check",
      "lint": "bunx turbo lint",
      "lintFix": "bunx turbo lint:fix",
      "formatFix": "bunx turbo lint:fix"
    }
  },
  "review": {
    "enabled": true,
    "checks": [
      "build",
      "typecheck",
      "lint",
      "semantic",
      "adversarial"
    ],
    "commands": {
      "build": "bun run build",
      "typecheck": "bunx turbo type-check",
      "lint": "bunx turbo lint",
      "lintFix": "bunx turbo lint:fix"
    }
  },
  "context": {
    "fileInjection": "keyword",
    "v2": {
      "enabled": true,
      "minScore": 0.1,
      "rules": {
        "allowLegacyClaudeMd": false
      }
    }    
  },
  "plan": {
    "model": "balanced"
  },
  "acceptance": {
    "enabled": true,
    "maxRetries": 3
  },
  "precheck": {
    "storySizeGate": {
      "enabled": true,
      "maxAcCount": 15,
      "maxBulletPoints": 15
    }
  }
}
