{
  "quality": {
    "commands": {
      "build": "bun run build:generate",
      "test": "bun run test",
      "testScoped": "bunx jest {{files}} --forceExit --passWithNoTests --testPathIgnorePatterns=integration",
      "typecheck": "bun run type-check",
      "lint": "bun run lint",
      "lintFix": "bun run lint:fix",
      "formatFix": "bun run lint:fix"
    }
  },
  "execution": {
    "smartTestRunner": {
      "testFilePatterns": [
        "**/__tests__/**/*.js",
        "**/__tests__/**/*.jsx",
        "**/__tests__/**/*.ts",
        "**/__tests__/**/*.tsx",
        "**/spec.js",
        "**/spec.jsx",
        "**/spec.ts",
        "**/spec.tsx",
        "**/test.js",
        "**/test.jsx",
        "**/test.ts",
        "**/test.tsx",
        "**/*.spec.js",
        "**/*.spec.jsx",
        "**/*.spec.ts",
        "**/*.spec.tsx",
        "**/*.test.js",
        "**/*.test.jsx",
        "**/*.test.ts",
        "**/*.test.tsx"
      ]
    }
  },
  "acceptance": {
    "testFramework": "jest",
    "command": "npx jest --runTestsByPath {{FILE}}"
  }
}
