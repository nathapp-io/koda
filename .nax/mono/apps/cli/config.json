{
  "quality": {
    "commands": {
      "build": "bun run build",
      "test": "bun run test",
      "testScoped": "bunx jest {{files}} --forceExit --passWithNoTests",
      "typecheck": "bun run type-check",
      "lint": "bun run lint",
      "lintFix": "bun run lint:fix",
      "formatFix": "bun run lint:fix"
    }
  },
  "execution": {
    "smartTestRunner": {
      "testFilePatterns": [
        "**/__tests__/**/*.[jt]s?(x)",
        "**/?(*.)+(spec|test).[jt]s?(x)",
        "**/__tests__/**/*.js",
        "**/__tests__/**/*.jsx",
        "**/__tests__/**/*.ts",
        "**/__tests__/**/*.tsx",
        "**/*.spec.js",
        "**/*.spec.jsx",
        "**/*.spec.ts",
        "**/*.spec.tsx",
        "**/*.test.js",
        "**/*.test.jsx",
        "**/*.test.ts",
        "**/*.test.tsx"
      ]
    }
  }
}
