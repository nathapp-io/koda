{
  "quality": {
    "commands": {
      "build": "bun run build",
      "typecheck": "bun run type-check",
      "lint": "bun run lint",
      "lintFix": "bun run lint:fix"
    }
  },
  "execution": {
    "smartTestRunner": {
      "testFilePatterns": [
        "**/*.spec.ts",
        "./tests/e2e/**/*.spec.{ts,js}",
        "**/__tests__/**/*.[jt]s?(x)",
        "**/?(*.)+(spec|test).[jt]s?(x)"
      ]
    }
  }
}
