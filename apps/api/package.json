{
  "name": "@nathapp/koda-api",
  "version": "0.2.1",
  "private": true,
  "packageManager": "bun@1.3.7",
  "scripts": {
    "build": "nest build",
    "build:generate": "prisma generate && nest build",
    "dev": "nest start --watch",
    "start": "bun dist/main",
    "start:prod-runtime": "ENV_NAME=production bun /app/apps/runtime/dist/main",
    "test": "jest --forceExit --passWithNoTests --testPathIgnorePatterns=integration",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage --forceExit",
    "lint": "eslint \"{src,test}/**/*.ts\" --max-warnings=0",
    "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
    "type-check": "tsc --noEmit",
    "test:unit": "jest --forceExit --passWithNoTests --testPathIgnorePatterns=integration",
    "test:integration": "DATABASE_URL=file:./koda-test.db jest --forceExit --passWithNoTests --testPathPattern=integration",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "seed:e2e": "bun prisma/seed-e2e.ts"
  },
  "dependencies": {
    "@fastify/static": "^9.0.0",
    "@lancedb/lancedb": "0.17.0",
    "@nathapp/nestjs-app": "^3.0.0",
    "@nathapp/nestjs-auth": "^3.0.0",
    "@nathapp/nestjs-common": "^3.0.0",
    "@nathapp/nestjs-logging": "^3.0.0",
    "@nathapp/nestjs-prisma": "^3.1.0",
    "@nathapp/nestjs-throttler": "^3.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-fastify": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@prisma/client": "^6.0.0",
    "bcrypt": "^5.1.0",
    "class-transformer": "^0.5.0",
    "class-validator": "^0.14.0",
    "joi": "^18.0.2",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@nathapp/eslint-config": "workspace:*",
    "@nathapp/typescript-config": "workspace:*",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/bcrypt": "^5.0.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.0",
    "dotenv": "^17.3.1",
    "jest": "^29.0.0",
    "prisma": "^6.0.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.0.0",
    "typescript": "^5.4.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "roots": [
      "<rootDir>",
      "<rootDir>/../test/e2e",
      "<rootDir>/../test/integration"
    ],
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "forceExit": true,
    "setupFilesAfterEnv": [
      "<rootDir>/../test-setup.ts"
    ]
  }
}
