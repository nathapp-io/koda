{
  "name": "@nathapp/koda-cli",
  "version": "0.1.0",
  "description": "CLI for Koda — dev ticket tracker",
  "bin": {
    "koda": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest --forceExit --passWithNoTests",
    "test:watch": "jest --watch",
    "lint": "eslint \"src/**/*.ts\" --ignore-pattern \"src/generated/**\" --max-warnings=0",
    "lint:fix": "eslint \"src/**/*.ts\" --ignore-pattern \"src/generated/**\" --fix",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@hey-api/client-axios": "^0.3.0",
    "axios": "^1.7.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "conf": "^13.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^22.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.4.0"
  }
}
