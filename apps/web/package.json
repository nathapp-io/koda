{
  "name": "@nathapp/koda-web",
  "version": "0.2.4",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev --port 3101",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "lint": "eslint \"./**/*.ts\" --ignore-pattern \".nuxt/**\" --ignore-pattern \".output/**\" --ignore-pattern \"generated/**\" --max-warnings=0",
    "lint:fix": "eslint \"./**/*.ts\" --ignore-pattern \".nuxt/**\" --ignore-pattern \".output/**\" --ignore-pattern \"generated/**\" --fix",
    "type-check": "nuxt typecheck",
    "test": "jest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@nuxtjs/color-mode": "^3.5.2",
    "@nuxtjs/i18n": "^10.2.3",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@vee-validate/zod": "^4.15.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^0.400.0",
    "nuxt": "^3.21.2",
    "radix-vue": "^1.9.17",
    "shadcn-nuxt": "^0.10.4",
    "tailwind-merge": "^2.6.1",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.30",
    "vue-router": "^4.6.4",
    "vue-sonner": "^2.0.9",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "@nathapp/eslint-config": "workspace:*",
    "@nathapp/typescript-config": "workspace:*",
    "@hey-api/client-fetch": "^0.3.4",
    "@nuxt/devtools": "latest",
    "@nuxt/eslint": "^0.7.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.15",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.9.3",
    "vue-tsc": "^2.2.12"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/tests",
      "<rootDir>"
    ],
    "testMatch": [
      "**/*.spec.ts"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/tests/e2e/",
      ".nax/"
    ],
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ],
    "moduleNameMapper": {
      "^~/(.*)$": "<rootDir>/$1",
      "^~$": "<rootDir>"
    },
    "transform": {
      "^.+\\.ts$": [
        "<rootDir>/jest-transform.cjs",
        {
          "tsconfig": {
            "module": "commonjs",
            "target": "es2022",
            "moduleResolution": "node",
            "esModuleInterop": true,
            "allowSyntheticDefaultImports": true,
            "skipLibCheck": true,
            "resolveJsonModule": true,
            "isolatedModules": true,
            "types": [
              "node",
              "jest"
            ]
          }
        }
      ]
    }
  }
}
