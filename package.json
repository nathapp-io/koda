{
  "name": "koda",
  "private": true,
  "packageManager": "bun@1.0.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:studio": "turbo run db:studio",
    "db:reset": "turbo run db:reset",
    "api:export-spec": "bash -c 'cd apps/api && bun run build && node scripts/export-spec.cjs'",
    "generate:cli": "openapi-ts --input openapi.json --output apps/cli/src/generated --client axios",
    "generate:web": "openapi-ts --input openapi.json --output apps/web/generated --client fetch",
    "generate": "bun run api:export-spec && bun run generate:cli && bun run generate:web"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.46.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.0.0",
    "tsx": "^4.21.0",
    "turbo": "^2.8.17",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.0.0"
  }
}
