{
  "name": "koda",
  "private": true,
  "packageManager": "bun@1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "db:generate": "prisma generate --schema=prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "db:migrate:prod": "prisma migrate deploy --schema=prisma/schema.prisma",
    "db:studio": "prisma studio --schema=prisma/schema.prisma",
    "db:reset": "prisma migrate reset --schema=prisma/schema.prisma",
    "api:export-spec": "ts-node -r tsconfig-paths/register apps/api/scripts/export-spec.ts",
    "generate:cli": "openapi-ts --input openapi.json --output packages/cli/src/generated --client axios",
    "generate:web": "openapi-ts --input openapi.json --output apps/web/generated --client fetch",
    "generate": "bun run api:export-spec && bun run generate:cli && bun run generate:web"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.46.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "prisma": "^6.0.0",
    "@types/node": "^22.0.0"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.0.0"
  }
}
