{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./base.json",   
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "incremental": true,
    "strictNullChecks": false,
    "strictBindCallApply": false,
    "forceConsistentCasingInFileNames": false,
    "noFallthroughCasesInSwitch": false,
  }
}
