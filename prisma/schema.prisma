generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// --- Enums ---
// SQLite doesn't support native enums, so we map them to String fields.

// --- Phase 1 Models ---

model User {
  id String @id @default(cuid())
  email String @unique
  name String?
  passwordHash String
  role UserRole @default(MEMBER) // MEMBER | ADMIN
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdTickets Ticket[] @relation("TicketCreatedByUser")
  assignedTickets Ticket[] @relation("TicketAssignedToUser")
  comments Comment[]
  activities TicketActivity[] @relation("ActivityByUser")
}

model Agent {
  id String @id @default(cuid())
  name String
  slug String @unique
  apiKeyHash String @unique
  status String @default("ACTIVE") // ACTIVE | PAUSED | OFFLINE
  maxConcurrentTickets Int @default(3)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roles AgentRoleEntry[]
  capabilities AgentCapabilityEntry[]
  createdTickets Ticket[] @relation("TicketCreatedByAgent")
  assignedTickets Ticket[] @relation("TicketAssignedToAgent")
  comments Comment[]

  projects AgentProject[] @relation("AgentProjects") // Relation name for Agent to AgentProject
}

model AgentRoleEntry {
  id String @id @default(cuid())
  agentId String
  role String // VERIFIER | DEVELOPER | REVIEWER

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, role])
}

model AgentCapabilityEntry {
  id String @id @default(cuid())
  agentId String
  capability String

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, capability])
}

// --- Phase 2 Models ---

model Project {
  id String @id @default(cuid())
  name String
  slug String @unique
  key String @unique // e.g. KODA — used in ticket refs
  description String?
  gitRemoteUrl String?
  autoIndexOnClose Boolean @default(true)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tickets Ticket[] @relation("ProjectTickets")
  agents AgentProject[] @relation("ProjectAgents") // Relation name for Project to AgentProject
  labels Label[]
}

model Ticket {
  id String @id @default(cuid())
  projectId String
  number Int // auto-incremented per project
  type String @map("type") // BUG | ENHANCEMENT | TASK | QUESTION
  title String
  description String?
  status String @default("CREATED") // CREATED | VERIFIED | IN_PROGRESS | VERIFY_FIX | CLOSED | REJECTED
  priority String @default("MEDIUM") // LOW | MEDIUM | HIGH | CRITICAL
  assignedToUserId String?
  assignedToAgentId String?
  createdByUserId String?
  createdByAgentId String?
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation("ProjectTickets", fields: [projectId], references: [id])
  assignedToUser User? @relation("TicketAssignedToUser", fields: [assignedToUserId], references: [id])
  assignedToAgent Agent? @relation("TicketAssignedToAgent", fields: [assignedToAgentId], references: [id])
  createdByUser User? @relation("TicketCreatedByUser", fields: [createdByUserId], references: [id])
  createdByAgent Agent? @relation("TicketCreatedByAgent", fields: [createdByAgentId], references: [id])
  comments Comment[]
  labels TicketLabel[]
  activities TicketActivity[]
}

model Comment {
  id String @id @default(cuid())
  ticketId String
  body String
  type String @default("GENERAL") // GENERAL | VERIFICATION | FIX_REPORT | REVIEW
  userId String?
  agentId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ticket Ticket @relation(fields: [ticketId], references: [id])
  user User? @relation("CommentByUser", fields: [userId], references: [id])
  agent Agent? @relation("CommentByAgent", fields: [agentId], references: [id])
}

model Label {
  id String @id @default(cuid())
  projectId String
  name String
  color String?

  project Project @relation(fields: [projectId], references: [id])
  tickets TicketLabel[]

  @@unique([projectId, name])
  @@index([projectId])
}

model TicketLabel {
  ticketId String
  labelId String

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([ticketId, labelId])
}

model TicketActivity {
  id String @id @default(cuid())
  ticketId String
  action String // STATUS_CHANGE | ASSIGNMENT | COMMENT
  fromStatus String?
  toStatus String?
  actorId String?
  actorType String? // user | agent
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id])
}

// Many-to-many relationship between Agent and Project
model AgentProject {
  agentId String
  projectId String

  agent Agent @relation("AgentProjects", fields: [agentId], references: [id], onDelete: Cascade) // Link from AgentProject to Agent
  project Project @relation("ProjectAgents", fields: [projectId], references: [id], onDelete: Cascade) // Link from AgentProject to Project

  @@id([agentId, projectId])
}

// Enum definitions (for TypeScript code generation, not directly used in SQLite)
// All enums are mapped to String in the SQLite database

enum UserRole {
  ADMIN
  MEMBER
}

enum LabelColor {
  RED
  ORANGE
  YELLOW
  GREEN
  BLUE
  PURPLE
}

enum TicketStatus {
  CREATED
  VERIFIED
  IN_PROGRESS
  VERIFY_FIX
  CLOSED
  REJECTED
}

enum TicketType {
  BUG
  ENHANCEMENT
  TASK
  QUESTION
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CommentType {
  GENERAL
  VERIFICATION
  FIX_REPORT
  REVIEW
}
